.env
.env.*
!.env.example

# Local vector database/index generated at runtime
.chroma/

# Logs and runtime files
*.log
*.pid

# IDE/editor files
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db
